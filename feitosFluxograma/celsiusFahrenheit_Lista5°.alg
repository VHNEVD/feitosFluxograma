algoritmo "converterCelsiusFahrenheit"
// Autor :Victor Hugo
// Data : 13/04/2026
var
//variação
          C, F: real
          
inicio
// Seção de Comandos 
   Escreva("Digite a temperatura em Celsius: ")
   Leia(c)
   
   F<-(9 * C / 5) + 32
   
   Escreval("A temperatura em Fahrenheit é: ", F)
   
fimalgoritmo
