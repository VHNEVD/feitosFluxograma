algoritmo "soma de dois algoritimos"
// Autor : Victor Hugo
// Data : 07/04/2026
// F9 pra executar
var
   N1,N2,soma: real

inicio
// Entradas
   escreva("Adicione Número 1: ")
   leia(N1)
   escreva("Adicione Número 2: ")
   leia(N2)
   //calculo
   soma <- n1+n2
   escreva("A soma dos numeros é igual " , soma)
   
fimalgoritmo
